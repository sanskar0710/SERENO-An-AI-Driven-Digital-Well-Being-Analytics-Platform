{
  "name": "sereno-platform",
  "version": "1.0.0",
  "description": "AI-Driven Digital Well-Being & Community Platform",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && pip install -r requirements.txt",
    "build": "cd frontend && npm run build",
    "start": "cd frontend && npm start"
  },
  "keywords": ["ai", "mental-health", "well-being", "community", "journaling"],
  "author": "Sereno Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
